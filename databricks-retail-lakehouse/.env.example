# Copy this file to .env and replace every placeholder.
# Never commit .env.

# Databricks deployment values
DATABRICKS_HOST=https://adb-<workspace-id>.<region>.azuredatabricks.net
DATABRICKS_CONFIG_PROFILE=retail-dev
DATABRICKS_BUNDLE_TARGET=dev

# Unity Catalog object names
RETAIL_CATALOG=retail_dev
RETAIL_SOURCE_SCHEMA=retail_sources
RETAIL_OUTPUT_SCHEMA=retail_lakehouse
RETAIL_VOLUME=landing

# Azure/Unity Catalog bootstrap values
RETAIL_STORAGE_ACCOUNT=<storage-account-name>
RETAIL_STORAGE_CONTAINER=databricks
RETAIL_STORAGE_PREFIX=retail-dev
RETAIL_STORAGE_CREDENTIAL=retail_lakehouse_storage_credential
RETAIL_EXTERNAL_LOCATION=retail_managed_location

# Databricks principal receiving project grants, usually your login email
DATABRICKS_PRINCIPAL=<your-databricks-login>
