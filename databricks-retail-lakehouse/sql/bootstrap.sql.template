-- Render a local sql/bootstrap.generated.sql from .env by running:
--   python scripts/render_bootstrap.py
-- The generated file is ignored by Git.

CREATE EXTERNAL LOCATION IF NOT EXISTS ${RETAIL_EXTERNAL_LOCATION}
URL 'abfss://${RETAIL_STORAGE_CONTAINER}@${RETAIL_STORAGE_ACCOUNT}.dfs.core.windows.net/${RETAIL_STORAGE_PREFIX}'
WITH (STORAGE CREDENTIAL ${RETAIL_STORAGE_CREDENTIAL})
COMMENT 'Governed storage for the retail lakehouse portfolio project';

GRANT CREATE MANAGED STORAGE
ON EXTERNAL LOCATION ${RETAIL_EXTERNAL_LOCATION}
TO `${DATABRICKS_PRINCIPAL}`;

CREATE CATALOG IF NOT EXISTS ${RETAIL_CATALOG}
MANAGED LOCATION 'abfss://${RETAIL_STORAGE_CONTAINER}@${RETAIL_STORAGE_ACCOUNT}.dfs.core.windows.net/${RETAIL_STORAGE_PREFIX}/catalog'
COMMENT 'Retail lakehouse portfolio catalog';

CREATE SCHEMA IF NOT EXISTS ${RETAIL_CATALOG}.${RETAIL_SOURCE_SCHEMA}
COMMENT 'Landing and source data';

CREATE SCHEMA IF NOT EXISTS ${RETAIL_CATALOG}.${RETAIL_OUTPUT_SCHEMA}
COMMENT 'Bronze, Silver, and Gold lakehouse tables';

CREATE VOLUME IF NOT EXISTS ${RETAIL_CATALOG}.${RETAIL_SOURCE_SCHEMA}.${RETAIL_VOLUME}
COMMENT 'Landing volume for generated retail source files';

GRANT USE CATALOG ON CATALOG ${RETAIL_CATALOG}
TO `${DATABRICKS_PRINCIPAL}`;

GRANT USE SCHEMA, CREATE TABLE, CREATE VOLUME
ON SCHEMA ${RETAIL_CATALOG}.${RETAIL_SOURCE_SCHEMA}
TO `${DATABRICKS_PRINCIPAL}`;

GRANT USE SCHEMA, CREATE TABLE
ON SCHEMA ${RETAIL_CATALOG}.${RETAIL_OUTPUT_SCHEMA}
TO `${DATABRICKS_PRINCIPAL}`;
